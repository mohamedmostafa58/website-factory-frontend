---
import type { ImageGalleryBlock } from '@/lib/types'

interface Props {
  block: ImageGalleryBlock
}

const { block } = Astro.props

const colClasses: Record<string, string> = {
  '2': 'grid-cols-1 sm:grid-cols-2',
  '3': 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3',
  '4': 'grid-cols-2 sm:grid-cols-3 lg:grid-cols-4',
}
---

<section class="py-12 px-4">
  <div class="max-w-7xl mx-auto">
    {block.heading && (
      <h2 class="text-3xl font-heading font-bold mb-8 text-center text-on-surface">
        {block.heading}
      </h2>
    )}
    <div class={`grid gap-4 ${colClasses[block.columns] ?? colClasses['3']}`}>
      {block.images?.map((item) => (
        <figure class="group overflow-hidden rounded-theme">
          <div class="aspect-square overflow-hidden">
            <img
              src={item.image?.url}
              alt={item.alt || item.image?.alt || ''}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          </div>
          {item.caption && (
            <figcaption class="mt-2 text-sm text-gray-500 text-center">
              {item.caption}
            </figcaption>
          )}
        </figure>
      ))}
    </div>
  </div>
</section>
