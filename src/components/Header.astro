---
import type { NavLink } from '@/lib/types'

interface Props {
  siteName: string
  links: NavLink[]
}

const { siteName, links } = Astro.props
---

<header class="bg-surface border-b border-gray-200 sticky top-0 z-50 backdrop-blur-sm bg-opacity-90">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      {/* Logo / Site Name */}
      <a href="/" class="text-xl font-heading font-bold text-primary hover:opacity-80 transition-opacity">
        {siteName}
      </a>

      {/* Desktop Navigation — dynamically built from Payload headerLinks */}
      <div class="hidden md:flex items-center space-x-1">
        {links.map((link) => (
          <div class="relative group">
            <a
              href={link.url}
              target={link.openInNewTab ? '_blank' : undefined}
              rel={link.openInNewTab ? 'noopener noreferrer' : undefined}
              class="px-3 py-2 text-sm font-medium text-on-surface hover:text-primary rounded-theme transition-colors"
            >
              {link.label}
              {link.children && link.children.length > 0 && (
                <svg class="inline-block w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              )}
            </a>

            {/* Dropdown */}
            {link.children && link.children.length > 0 && (
              <div class="absolute left-0 mt-0 w-48 bg-surface rounded-theme shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 border border-gray-100">
                <div class="py-1">
                  {link.children.map((child) => (
                    <a
                      href={child.url}
                      target={child.openInNewTab ? '_blank' : undefined}
                      rel={child.openInNewTab ? 'noopener noreferrer' : undefined}
                      class="block px-4 py-2 text-sm text-on-surface hover:bg-primary-light hover:text-primary transition-colors"
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
      </div>

      {/* Mobile menu button */}
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-theme text-on-surface hover:bg-gray-100 transition-colors"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    {/* Mobile Navigation */}
    <div id="mobile-menu" class="md:hidden hidden pb-4">
      {links.map((link) => (
        <div>
          <a
            href={link.url}
            target={link.openInNewTab ? '_blank' : undefined}
            class="block px-3 py-2 text-base font-medium text-on-surface hover:text-primary hover:bg-primary-light rounded-theme transition-colors"
          >
            {link.label}
          </a>
          {link.children?.map((child) => (
            <a
              href={child.url}
              target={child.openInNewTab ? '_blank' : undefined}
              class="block pl-6 pr-3 py-2 text-sm text-gray-600 hover:text-primary transition-colors"
            >
              {child.label}
            </a>
          ))}
        </div>
      ))}
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn')
  const menu = document.getElementById('mobile-menu')
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden')
  })
</script>
